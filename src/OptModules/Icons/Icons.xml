<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/
    https://raw.githubusercontent.com/Gethe/wow-ui-source/live/Interface/FrameXML/UI.xsd">
    <!--
      Opt-in icon support for MBLib consumers. Reference this from your
      addon's loader XML alongside MBLib.xml when (and only when) you
      use MBLib.IconPicker / MBLib.IconFrame:

          <Include file="MBLib\MBLib.xml"/>
          <Include file="MBLib\OptModules\Icons\Icons.xml"/>

      Skipping this file saves loading IconCatalog.lua (~1.4 MB) for
      addons that never surface an icon picker. The modules below
      assume MBLib.xml has already been loaded — they reference
      MBLib.L, MBLib._addonName etc. at file scope.
    -->
    <Script file="IconFrame.lua"/>
    <Script file="IconCatalog.lua"/>
    <Script file="IconPicker.lua"/>
</Ui>
