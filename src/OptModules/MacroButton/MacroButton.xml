<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/
    https://raw.githubusercontent.com/Gethe/wow-ui-source/live/Interface/FrameXML/UI.xsd">
    <!--
      Opt-in macro-button support. Reference this from a consumer
      addon's loader XML alongside MBLib.xml when the addon wants
      the "drag a macro to your action bar" affordance on its
      Settings page:

          <Include file="MBLib\MBLib.xml"/>
          <Include file="MBLib\OptModules\MacroButton\MacroButton.xml"/>

      Provides:
        - MBLib.MacroButton  the button + its drag-to-actionbar logic

      Consumers opt in via ``addon.MBLib:SetMacroButton({ ... })``.
    -->
    <Script file="MacroButton.lua"/>
</Ui>
