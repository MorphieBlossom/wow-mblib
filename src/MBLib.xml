<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/
    https://raw.githubusercontent.com/Gethe/wow-ui-source/live/Interface/FrameXML/UI.xsd">
    <!-- Embed entrypoint. Reference this from a consumer addon's loader XML:
            <Include file="MBLib\MBLib.xml"/>

         Layout:
            CoreModules/   modules always loaded with MBLib (referenced below)
            OptModules/    opt-in features with their own loader XMLs;
                           reference each separately from your loader when needed:
                             OptModules\Movers\Movers.xml
                             OptModules\MacroButton\MacroButton.xml
                             OptModules\Fonts\Fonts.xml
                             OptModules\Icons\Icons.xml -->
    <Include file="Libraries\Load_Libraries.xml"/>
    <Script file="Init.lua"/>
    <Script file="CoreModules\Strings.lua"/>
    <Script file="CoreModules\Constants.lua"/>
    <Script file="CoreModules\Utils.lua"/>
    <Script file="CoreModules\Settings.lua"/>
    <Script file="CoreModules\Commands.lua"/>
    <Script file="CoreModules\Changelog.lua"/>
    <Script file="CoreModules\Notifications.lua"/>
    <Script file="CoreModules\CopyPopup.lua"/>
    <Script file="CoreModules\OptionsScreen.lua"/>
    <!-- <Script file="CoreModules\CustomOptionsScreen.lua"/> -->
</Ui>
